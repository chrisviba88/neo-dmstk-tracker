#!/bin/bash
# Pre-commit hook: bloquea commits que contengan API keys o secrets
# Instalado automaticamente. NO desactivar.

PATTERNS=(
  "AIzaSy"          # Google/Gemini API keys
  "eyJhbGciOi"      # JWT tokens (Supabase, etc)
  "sk-[a-zA-Z0-9]{20}"  # OpenAI keys (20+ chars after sk-)
  "ghp_"            # GitHub personal tokens
  "gho_"            # GitHub OAuth tokens
  "xoxb-"           # Slack bot tokens
  "xoxp-"           # Slack user tokens
  "SUPABASE_SERVICE_KEY=eyJ"  # Supabase service key with value
)

# Solo revisar archivos staged (no .env que estan en gitignore)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '\.env' | grep -v 'node_modules' | grep -v '\.gitignore' | grep -v 'pre-commit')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND=0
for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -l "$pattern" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo ""
    echo "=========================================="
    echo "  BLOQUEADO: API key detectada en commit"
    echo "=========================================="
    echo ""
    echo "Patron: $pattern"
    echo "Archivos:"
    echo "$MATCHES" | while read f; do
      echo "  - $f"
      grep -n "$pattern" "$f" | head -3 | while read line; do
        echo "    $line"
      done
    done
    echo ""
    echo "Mueve la key a una variable de entorno (.env)"
    echo "y usa import.meta.env.VITE_* en el frontend."
    echo ""
    FOUND=1
  fi
done

if [ $FOUND -eq 1 ]; then
  echo "Commit cancelado. Elimina las keys antes de commitear."
  exit 1
fi

exit 0
